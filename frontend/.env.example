VITE_API_BASE_URL=http://localhost:8000/api

# WorkOS AuthKit (Staging environment for local dev).
# The Client ID is public; it must match the backend's WORKOS_CLIENT_ID.
# The redirect URI must be registered in the WorkOS Dashboard, exactly.
VITE_WORKOS_CLIENT_ID=your-workos-client-id
VITE_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
