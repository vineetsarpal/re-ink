# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/reink_db

# Extraction backend: "landingai" (default), "openai", "anthropic", or "free"
EXTRACTION_BACKEND=landingai

# LandingAI Configuration (required only when EXTRACTION_BACKEND=landingai)
LANDINGAI_API_KEY=your_landingai_api_key
LANDINGAI_PARSE_URL=https://api.va.landing.ai/v1/ade/parse
LANDINGAI_EXTRACT_URL=https://api.va.landing.ai/v1/ade/extract
LANDINGAI_PARSE_MODEL=dpt-2-latest
LANDINGAI_EXTRACT_MODEL=extract-latest

# Free Extraction Configuration (used when EXTRACTION_BACKEND=free)
# FREE_PARSE_BACKEND=pypdf         # "pypdf" (text-based PDFs only) or "glm-ocr" (scanned + complex PDFs via Ollama VLM)
# FREE_PARSE_MODEL=glm-ocr         # Ollama model for parse step — run: ollama pull glm-ocr
# FREE_LLM_PROVIDER=openai         # "openai" uses OPENAI_API_KEY below; "ollama" is fully local/free
# FREE_LLM_MODEL=gpt-4o-mini       # model name for the chosen provider (e.g. "llama3.1:8b" for ollama)
# FREE_OLLAMA_BASE_URL=http://localhost:11434  # Ollama server URL (used for both glm-ocr parse and ollama extract)

# OpenAI Configuration (required for agents and for free/openai extraction backends)
OPENAI_API_KEY=your_openai_api_key

# Anthropic Configuration (required for anthropic extraction backend)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Application Settings
APP_NAME="re-ink"
APP_VERSION="1.0.0"
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# File Upload Settings
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
UPLOAD_DIR=./uploads

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO
